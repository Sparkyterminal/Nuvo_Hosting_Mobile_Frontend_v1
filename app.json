{
  "expo": {
    "name": "NovoHosting",
    "slug": "novohosting",
    "version": "1.0.0",
    "splash": {
      "backgroundColor": "#5B4C3A"
    },
    "icon": "./assets/icon.png",
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#5B4C3A",
          "image": "./assets/novoLogo.png",
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#5B4C3A",
            "image": "./assets/novoLogo.png",
            "resizeMode": "contain"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-font"
    ],
    "android": {
      "package": "com.rudreshac.novohosting",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#5B4C3A"
      }
    },
    "ios": {
      "bundleIdentifier": "com.rudreshac.novohosting"
    },
    "extra": {
      "eas": {
        "projectId": "807417d9-ee29-4c5f-83c9-c6c3b3520c5f"
      }
    }
  }
}
